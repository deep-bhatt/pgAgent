# pgAgent Configuration
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env

# ── PostgreSQL Connection ─────────────────────────────────────────────
PGAGENT_PG_DSN=postgresql://pgagent:pgagent@localhost:5433/demo

# ── LLM (optional — leave empty to disable index recommendations) ────
PGAGENT_GROQ_API_KEY=
PGAGENT_LLM_MODEL=llama-3.3-70b-versatile
PGAGENT_LLM_TIMEOUT_SECONDS=30

# ── Observer ──────────────────────────────────────────────────────────
PGAGENT_OBSERVE_INTERVAL_SECONDS=60

# ── Detection Thresholds ─────────────────────────────────────────────
PGAGENT_DEAD_TUPLE_RATIO_THRESHOLD=0.05
PGAGENT_SEQ_SCAN_RATIO_THRESHOLD=0.5
PGAGENT_IDLE_TRANSACTION_SECONDS=300
PGAGENT_CONNECTION_SATURATION_RATIO=0.8

# ── Suggestion Queue ─────────────────────────────────────────────────
PGAGENT_AUTO_APPROVE_LOW_RISK=false
PGAGENT_SUGGESTION_TTL_SECONDS=3600

# ── Safety Limits ────────────────────────────────────────────────────
PGAGENT_MAX_INDEX_CREATES_PER_HOUR=3
PGAGENT_MAX_CONCURRENT_MUTATIONS=1

# ── API Server ───────────────────────────────────────────────────────
PGAGENT_API_HOST=0.0.0.0
PGAGENT_API_PORT=8420

# ── Sidecar DB ───────────────────────────────────────────────────────
PGAGENT_SIDECAR_DB_PATH=pgagent_sidecar.db
